# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/formbuilder?schema=public"

# Server Configuration
PORT=3000

# CORS Configuration (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173
ALLOW_IN_MEMORY_RATE_LIMIT=true
TRUST_PROXY_HOPS=0

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (PDPA Compliance)
ENCRYPTION_KEY=your-32-character-encryption-key!
IP_HASH_SALT=your-ip-hash-salt-for-anonymization

# Cloudflare Turnstile
CLOUDFLARE_TURNSTILE_SECRET=your-cloudflare-turnstile-secret
AUTH_TURNSTILE_REQUIRED=false

# Export Controls
EXPORT_DISTRIBUTED_ONLY=false
EXPORT_LOCK_TTL_SECONDS=1800
EXPORT_RESULT_TTL_SECONDS=900
EXPORT_IDEMPOTENCY_TTL_SECONDS=86400

# Auth Refresh Cookie Controls
AUTH_REFRESH_COOKIE_ENABLED=true
AUTH_REFRESH_COOKIE_ONLY=true
AUTH_REFRESH_COOKIE_NAME=fb_refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_SECURE=false
