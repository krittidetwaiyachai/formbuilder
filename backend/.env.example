# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/formbuilder?schema=public"

# Server Configuration
PORT=3000

# CORS Configuration (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173
ALLOW_IN_MEMORY_RATE_LIMIT=true

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production

# Encryption (PDPA Compliance)
ENCRYPTION_KEY=your-32-character-encryption-key!
IP_HASH_SALT=your-ip-hash-salt-for-anonymization

# Export Controls
EXPORT_DISTRIBUTED_ONLY=false
EXPORT_LOCK_TTL_SECONDS=1800
EXPORT_RESULT_TTL_SECONDS=900
EXPORT_IDEMPOTENCY_TTL_SECONDS=86400
