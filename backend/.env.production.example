# ============================================================
# PRODUCTION Environment Configuration
# Copy this file to .env and fill in actual values
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://USER:PASSWORD@YOUR_DB_HOST:5432/formbuilder?schema=public&connection_limit=50&pool_timeout=60"

# --- Server ---
PORT=3000

# --- CORS (production domain only, comma-separated) ---
FRONTEND_URL="https://your-domain.com"
ALLOW_IN_MEMORY_RATE_LIMIT=false
TRUST_PROXY_HOPS=1

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- JWT (generate new secrets for production!) ---
JWT_SECRET=GENERATE_A_STRONG_RANDOM_64_CHAR_SECRET_HERE
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Encryption (PDPA Compliance — generate new keys!) ---
ENCRYPTION_KEY=GENERATE_A_64_CHAR_HEX_KEY_HERE
ENCRYPTION_SALT=GENERATE_A_32_CHAR_RANDOM_SALT
IP_HASH_SALT=GENERATE_A_44_CHAR_BASE64_SALT

# --- Cloudflare Turnstile ---
CLOUDFLARE_TURNSTILE_SECRET=your-turnstile-secret-key
AUTH_TURNSTILE_REQUIRED=true

# --- SMTP (Email) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=YOUR_SENDGRID_API_KEY
SMTP_FROM=noreply@your-domain.com

# --- Backup ---
BACKUP_ENCRYPTION_KEY=base64:GENERATE_A_32_BYTE_BASE64_KEY

# --- Auth Cookie ---
AUTH_REFRESH_COOKIE_ENABLED=true
AUTH_REFRESH_COOKIE_ONLY=true
AUTH_REFRESH_COOKIE_NAME=fb_refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_REFRESH_COOKIE_DOMAIN=your-domain.com
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_REUSE_MARKER_TTL_SECONDS=604800
AUTH_REFRESH_REUSE_GRACE_SECONDS=5

# --- Redis ---
REDIS_URL=redis://YOUR_REDIS_HOST:6379

# --- Health Check ---
HEALTH_VERBOSE_PUBLIC=false

# --- Export Controls ---
EXPORT_MAX_ROWS=200000
EXPORT_DISTRIBUTED_ONLY=true
EXPORT_LOCK_TTL_SECONDS=1800
EXPORT_RESULT_TTL_SECONDS=900
EXPORT_IDEMPOTENCY_TTL_SECONDS=86400
